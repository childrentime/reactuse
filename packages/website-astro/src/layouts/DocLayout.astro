---
import BaseLayout from './BaseLayout.astro'
import Navbar from '../components/Navbar.astro'
import Sidebar from '../components/Sidebar.astro'
import Footer from '../components/Footer.astro'
import type { Locale } from '../i18n/translations'

interface Props {
  title: string
  description?: string
  category?: string
  slug?: string
  locale?: Locale
}

const { title, description, category, slug, locale = 'en' } = Astro.props

// Build breadcrumbs for documentation pages (skip homepage)
const isHomepage = !category && (!slug || slug === 'index' || slug === '/')
const breadcrumbs = isHomepage ? [] : (() => {
  const crumbs = [{ name: 'Home', url: 'https://reactuse.com/' }]
  if (category) {
    const catLabel = category.charAt(0).toUpperCase() + category.slice(1)
    crumbs.push({ name: catLabel, url: `https://reactuse.com/${category}/` })
  }
  if (slug && slug !== 'index') {
    const hookName = slug.split('/').pop() || slug
    crumbs.push({ name: hookName, url: `https://reactuse.com/${slug}/` })
  }
  return crumbs
})()
---

<BaseLayout title={title} description={description} locale={locale} breadcrumbs={breadcrumbs}>
  <Navbar locale={locale} />
  <div class="page-shell">
    <Sidebar currentSlug={slug} locale={locale} />
    <main class="main-content">
      <article class="doc-prose">
        <slot />
      </article>
    </main>
  </div>
  <Footer locale={locale} />
</BaseLayout>
